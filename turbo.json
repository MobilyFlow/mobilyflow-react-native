{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build:android": {
      "env": ["ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "packages/mobilyflow-react-native-sdk/package.json",
        "packages/mobilyflow-react-native-sdk/android/**",
        "!packages/mobilyflow-react-native-sdk/android/build/**",
        "packages/mobilyflow-react-native-sdk/src/**/*.ts",
        "packages/mobilyflow-react-native-sdk/src/**/*.tsx",
        "packages/test-app/package.json",
        "packages/test-app/android/**",
        "!packages/test-app/android/.gradle/**",
        "!packages/test-app/android/build/**",
        "!packages/test-app/android/app/build/**"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": ["RCT_NEW_ARCH_ENABLED"],
      "inputs": [
        "packages/mobilyflow-react-native-sdk/package.json",
        "packages/mobilyflow-react-native-sdk/*.podspec",
        "packages/mobilyflow-react-native-sdk/ios/**",
        "packages/mobilyflow-react-native-sdk/src/**/*.ts",
        "packages/mobilyflow-react-native-sdk/src/**/*.tsx",
        "packages/test-app/package.json",
        "packages/test-app/ios/**",
        "!packages/test-app/ios/build/**",
        "!packages/test-app/ios/Pods/**"
      ],
      "outputs": []
    }
  }
}
